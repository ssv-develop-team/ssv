# =============================================================================
# Site Safety Vision — 环境变量配置
# =============================================================================
# 复制此文件为 .env 并按需修改:
#   cp .env.example .env
#
# shell 脚本通过 scripts/lib.sh 自动加载 .env
# Docker Compose 自动读取项目根目录的 .env
# Python agent 通过 python-dotenv 加载 .env
# =============================================================================

# ─── GStreamer ────────────────────────────────────────────────────────────────
# GStreamer 调试级别 (ssv*:4 = SSV 插件 DEBUG, ssv*:5 = TRACE)
GST_DEBUG=ssv*:4

# RTSP 视频源地址 (test / run 使用)
SSV_RTSP_URL=rtsp://user:pass@host:554/stream

# RTSP transport，默认 TCP，避免 localhost/IPv6 下 UDP 回传地址族不匹配
SSV_RTSP_PROTOCOLS=tcp

# RTSP jitter buffer 延迟，单位毫秒
SSV_RTSP_LATENCY=200

# 检查链路的默认超时时间 (仅无头模式)
SSV_CHECK_TIMEOUT=30s

# 推理模型路径 (test / run 使用)
SSV_MODEL_PATH=models/yolov8n.onnx

# ─── 显示 ─────────────────────────────────────────────────────────────────────
# 显示 sink 类型 (留空则自动优先 waylandsink -> glimagesink -> autovideosink)
SSV_DISPLAY_SINK=

# 检测框 overlay 默认关闭；当前插件路径仍为实验功能，优先保证视频窗口稳定
SSV_DISPLAY_OVERLAY=false

# ─── Redis (Docker Compose) ──────────────────────────────────────────────────
# Redis 映射到宿主机的端口
REDIS_PORT=6379

# ─── Qdrant (M7 启用) ────────────────────────────────────────────────────────
# QDRANT_PORT=6333
